<!-- Add this INSIDE your form, before submit button -->
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% layout('layouts/boilerplate') %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">Signup on WanderLust</h1>
    <div class="col-6 offset-3">
        <form action="/signup" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input name="username" id="username" type="text" 
                       class="form-control" required minlength="3" maxlength="50">
                <div class="valid-feedback">Username looks good!</div>
                <div class="invalid-feedback">Username must be 3-50 chars (letters/numbers/spaces only)</div>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input name="email" id="email" type="email" 
                       class="form-control" required minlength="3" maxlength="50">
              
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input name="password" id="password" type="password" 
                       class="form-control" required minlength="6" maxlength="100">
                <div class="valid-feedback">Password looks good!</div>
                <div class="invalid-feedback">Password must be 6-100 chars</div>
            </div>
            <div>
                <button class="btn btn-success">SignUp</button>
            </div>

        </form>
    </div>
</div>